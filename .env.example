# Ambiente — copie para .env e preencha com o projeto Supabase
# Dashboard → Project Settings → Database

# Connection string (Transaction pooler — porta 6543) para a app em runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connection string direta (porta 5432) para migrations Prisma
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Auth do painel gestor (JWT assinado)
SESSION_SECRET="troque-por-um-segredo-longo-aleatorio"

# Empresa padrão do site (slug) até multi-tenant por domínio
DEFAULT_COMPANY_SLUG="estetica-mvp"

# Opcional — cron de lembretes (Vercel Cron)
CRON_SECRET="troque-por-segredo-do-cron"

# URL pública (links nos e-mails)
APP_URL="https://estetica-automotiva-crm.vercel.app"

# E-mail de boas-vindas / comunicações
# Opção A — Resend (recomendado na Vercel): https://resend.com
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="Estética CRM <onboarding@seu-dominio.com>"

# Opção B — SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Estética CRM <noreply@seu-dominio.com>"

# Cobrança / planos PRO e PREMIUM
# demo = upgrade imediato sem cartão (apresentações)
# stripe = Checkout real (exige chaves abaixo)
BILLING_MODE="demo"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# STRIPE_PRICE_PREMIUM="price_..."

# Opcional — comunicações (WhatsApp / Agenda)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# GOOGLE_CALENDAR_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON=
